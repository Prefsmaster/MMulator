<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:P2000.UI.ViewModels"
        xmlns:local="using:P2000.UI.Views"
        x:DataType="vm:CassetteDeckVm"
        x:Class="P2000.UI.Views.CassetteDeckWindow"
        Title="Cassette Deck"
        Width="260" Height="320"
        MinWidth="220" MinHeight="250"
        CanResize="True"
        Background="#1a1a1a">

    <DockPanel Margin="10">

        <!-- ── Tape status panel ────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#252525"
                BorderBrush="#444" BorderThickness="1"
                CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
            <StackPanel Spacing="4">
                <!-- Tape label -->
                <TextBlock Text="{Binding TapeLabel}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{Binding HasTape, Converter={x:Static local:BoolToLedBrushConverter.Instance}}"
                           TextTrimming="CharacterEllipsis" />
                <!-- Direction + activity row -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{Binding DirectionText}"
                               FontSize="11" Foreground="#bbb"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7"
                                 Fill="{Binding IsActive, Converter={x:Static local:BoolToLedBrushConverter.Instance}}" />
                        <TextBlock Text="R/W" FontSize="10" Foreground="#777" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="🔒" FontSize="11" VerticalAlignment="Center"
                               IsVisible="{Binding IsWriteProtected}"
                               ToolTip.Tip="Write-protected" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Buttons ──────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#252525"
                BorderBrush="#444" BorderThickness="1"
                CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Mount…"
                        Command="{Binding MountCommand}"
                        MinWidth="80"
                        ToolTip.Tip="Insert a .cas or .p2000t cassette image" />
                <Button Content="Eject"
                        Command="{Binding EjectCommand}"
                        MinWidth="60"
                        ToolTip.Tip="Remove the current cassette (CIP goes absent)" />
            </StackPanel>
        </Border>

        <!-- ── Program list ─────────────────────────────────────────────────── -->
        <Border Background="#252525"
                BorderBrush="#444" BorderThickness="1"
                CornerRadius="4" Padding="8,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Programs on tape:"
                           FontSize="11" Foreground="#888"
                           Margin="0,0,0,4" />
                <!-- Empty-state message -->
                <TextBlock Text="—"
                           FontSize="11" Foreground="#555"
                           IsVisible="{Binding Programs.Count, Converter={x:Static local:ZeroToBoolConverter.Instance}}"
                           VerticalAlignment="Top" />
                <ListBox ItemsSource="{Binding Programs}"
                         Background="Transparent"
                         BorderThickness="0"
                         IsVisible="{Binding Programs.Count,
                             Converter={x:Static local:ZeroToBoolConverter.Instance},
                             ConverterParameter=invert}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontSize="12" FontFamily="Consolas,Courier New,monospace"
                                       Foreground="#ddd" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

    </DockPanel>
</Window>
