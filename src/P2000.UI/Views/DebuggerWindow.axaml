<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:P2000.UI.ViewModels"
        xmlns:local="using:P2000.UI.Views"
        x:DataType="vm:DebuggerWindowVm"
        x:Class="P2000.UI.Views.DebuggerWindow"
        Title="Debugger — P2000T"
        Width="900" Height="580"
        MinWidth="600" MinHeight="420"
        CanResize="True"
        Background="#1a1a1a">

    <Window.Styles>
        <Style Selector="TextBlock.reglabel">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,1" />
        </Style>
        <Style Selector="TextBlock.regvalue">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#d4d4d4" />
            <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,1" />
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#1e1e1e" BorderBrush="#444" BorderThickness="0,1,0,0"
                Padding="8,3">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{Binding IsPaused, Converter={x:Static local:BoolToLedBrushConverter.Instance}}"
                           FontSize="11" VerticalAlignment="Center" />
                <TextBlock Text="Register values are live (best-effort) when running; exact at break/step"
                           Foreground="#555" FontSize="10" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ── Satellite-window toolbar ───────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#252525" BorderBrush="#444" BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="VRAM…"
                        Command="{Binding OpenVramWindowCommand}"
                        MinWidth="64" FontSize="10"
                        ToolTip.Tip="Open the VRAM / pan window" />
                <Button Content="+ Memory Watch"
                        Command="{Binding AddMemoryWatchCommand}"
                        MinWidth="112" FontSize="10"
                        ToolTip.Tip="Open a new independent memory watch window" />
                <TextBlock Text="{Binding MemoryWatches.Count, StringFormat='{}{0} watch(es) open'}"
                           FontSize="10" Foreground="#666"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ── Main content ──────────────────────────────────────────────── -->
        <Grid ColumnDefinitions="230,*">

            <!-- ── Left: Register file ──────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="#252525" BorderBrush="#444" BorderThickness="0,0,1,0"
                    Padding="10,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Registers"
                               FontSize="11" FontWeight="SemiBold" Foreground="#aaa"
                               Margin="0,0,0,6" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid ColumnDefinitions="44,*,44,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,8,Auto,Auto,Auto,8,Auto,Auto,8,Auto">
                            <!-- Row 0: AF / BC -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Classes="reglabel" Text="AF" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.AF}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Classes="reglabel" Text="BC" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Classes="regvalue" Text="{Binding RegisterFile.BC}" />
                            <!-- Row 1: DE / HL -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Classes="reglabel" Text="DE" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.DE}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Classes="reglabel" Text="HL" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Classes="regvalue" Text="{Binding RegisterFile.HL}" />
                            <!-- Row 2: AF' / BC' -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Classes="reglabel" Text="AF'" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.AF2}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Classes="reglabel" Text="BC'" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Classes="regvalue" Text="{Binding RegisterFile.BC2}" />
                            <!-- Row 3: DE' / HL' -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Classes="reglabel" Text="DE'" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.DE2}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Classes="reglabel" Text="HL'" />
                            <TextBlock Grid.Row="3" Grid.Column="3" Classes="regvalue" Text="{Binding RegisterFile.HL2}" />
                            <!-- Row 4: IX / IY -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Classes="reglabel" Text="IX" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.IX}" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Classes="reglabel" Text="IY" />
                            <TextBlock Grid.Row="4" Grid.Column="3" Classes="regvalue" Text="{Binding RegisterFile.IY}" />
                            <!-- Row 5: SP / PC -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Classes="reglabel" Text="SP" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.SP}" />
                            <TextBlock Grid.Row="5" Grid.Column="2" Classes="reglabel" Text="PC" />
                            <TextBlock Grid.Row="5" Grid.Column="3" Classes="regvalue" Text="{Binding RegisterFile.PC}" />
                            <!-- Row 6: I / R -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Classes="reglabel" Text="I" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.I}" />
                            <TextBlock Grid.Row="6" Grid.Column="2" Classes="reglabel" Text="R" />
                            <TextBlock Grid.Row="6" Grid.Column="3" Classes="regvalue" Text="{Binding RegisterFile.R}" />
                            <!-- Row 7: WZ -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Classes="reglabel" Text="WZ" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.WZ}" />
                            <!-- Row 8: (8px spacer) -->
                            <!-- Row 9: F raw -->
                            <TextBlock Grid.Row="9" Grid.Column="0" Classes="reglabel" Text="F" />
                            <TextBlock Grid.Row="9" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.F}" />
                            <!-- Row 10: Flags header -->
                            <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="4"
                                       Text="SZYHXPNCv"
                                       FontSize="9" Foreground="#555"
                                       FontFamily="Consolas,Courier New,monospace" />
                            <!-- Row 11: Flags values -->
                            <TextBlock Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="4"
                                       Text="{Binding RegisterFile.FlagsText}"
                                       FontFamily="Consolas,Courier New,monospace"
                                       FontSize="11" Foreground="#e0b060" />
                            <!-- Row 12: (8px spacer) -->
                            <!-- Row 13: IFF1 / IFF2 -->
                            <TextBlock Grid.Row="13" Grid.Column="0" Classes="reglabel" Text="IFF1" />
                            <TextBlock Grid.Row="13" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.IFF1}" />
                            <TextBlock Grid.Row="13" Grid.Column="2" Classes="reglabel" Text="IFF2" />
                            <TextBlock Grid.Row="13" Grid.Column="3" Classes="regvalue" Text="{Binding RegisterFile.IFF2}" />
                            <!-- Row 14: IM -->
                            <TextBlock Grid.Row="14" Grid.Column="0" Classes="reglabel" Text="IM" />
                            <TextBlock Grid.Row="14" Grid.Column="1" Classes="regvalue" Text="{Binding RegisterFile.IM}" />
                            <!-- Row 15: (8px spacer) -->
                            <!-- Row 16: FieldTState -->
                            <TextBlock Grid.Row="16" Grid.Column="0" Grid.ColumnSpan="2"
                                       Classes="reglabel" Text="FT-state" />
                            <TextBlock Grid.Row="16" Grid.Column="2" Grid.ColumnSpan="2"
                                       Classes="regvalue" Text="{Binding RegisterFile.FieldTState}" />
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ── Right: disassembly + stepping (milestone 10) ─────────────── -->
            <DockPanel Grid.Column="1" Background="#1a1a1a">

                <!-- Stepping toolbar -->
                <Border DockPanel.Dock="Top"
                        Background="#252525" BorderBrush="#333" BorderThickness="0,0,0,1"
                        Padding="6,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Content="▶/⏸"
                                Command="{Binding RunPauseCommand}"
                                MinWidth="44" FontSize="11"
                                ToolTip.Tip="Run / Pause (F5)" />
                        <Button Content="⏎ Step"
                                Command="{Binding StepIntoCommand}"
                                MinWidth="56" FontSize="11"
                                ToolTip.Tip="Step into (F11)" />
                        <Button Content="↷ Over"
                                Command="{Binding StepOverCommand}"
                                MinWidth="56" FontSize="11"
                                ToolTip.Tip="Step over (F10)" />
                        <Button Content="↑ Out"
                                Command="{Binding StepOutCommand}"
                                MinWidth="50" FontSize="11"
                                ToolTip.Tip="Step out (Shift+F11)" />
                    </StackPanel>
                </Border>

                <!-- Disassembly list -->
                <ScrollViewer DockPanel.Dock="Top"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DisasmItems" ItemsSource="{Binding Disassembly.Lines}" Tapped="OnDisasmTapped">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding IsPC, Converter={x:Static local:BoolToPcBrushConverter.Instance}}"
                                        Padding="0,1">
                                    <Grid ColumnDefinitions="12,52,72,*">
                                        <!-- Breakpoint dot -->
                                        <Ellipse Grid.Column="0"
                                                 Width="7" Height="7"
                                                 Fill="{Binding HasBreakpoint, Converter={x:Static local:BoolToBpDotConverter.Instance}}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                        <!-- Address -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Address}"
                                                   FontFamily="Consolas,Courier New,monospace"
                                                   FontSize="11"
                                                   Foreground="#888"
                                                   VerticalAlignment="Center" />
                                        <!-- Bytes -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Bytes}"
                                                   FontFamily="Consolas,Courier New,monospace"
                                                   FontSize="11"
                                                   Foreground="#555"
                                                   VerticalAlignment="Center" />
                                        <!-- Mnemonic -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Text}"
                                                   FontFamily="Consolas,Courier New,monospace"
                                                   FontSize="11"
                                                   Foreground="#d4d4d4"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>

        </Grid>
    </DockPanel>

</Window>
