<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rendering="using:P2000.UI.Rendering"
        xmlns:local="using:P2000.UI.Views"
        xmlns:vm="using:P2000.UI.ViewModels"
        x:DataType="vm:DisplayWindowVm"
        x:Class="P2000.UI.Views.DisplayWindow"
        Title="MMulator — P2000T"
        Width="640" Height="530"
        MinWidth="320" MinHeight="280"
        Background="Black">

    <!-- Global keyboard shortcuts (F-keys used by the emulator control surface, §6). -->
    <Window.KeyBindings>
        <KeyBinding Gesture="F5"       Command="{Binding ToggleRunPauseCommand}" />
        <KeyBinding Gesture="F6"       Command="{Binding ToggleTurboCommand}" />
        <KeyBinding Gesture="F8"       Command="{Binding StepCommand}" />
        <KeyBinding Gesture="F11"      Command="{Binding WarmResetCommand}" />
        <KeyBinding Gesture="Shift+F11" Command="{Binding ColdResetCommand}" />
        <KeyBinding Gesture="F12"      Command="{Binding ScreenshotCommand}" />
    </Window.KeyBindings>

    <DockPanel DragDrop.AllowDrop="True">

        <!-- ── Menu bar ──────────────────────────────────────────────────────── -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Machine">
                <MenuItem Header="Run / _Pause"     HotKey="F5"        Command="{Binding ToggleRunPauseCommand}" />
                <Separator />
                <MenuItem Header="Reset (_Warm)"    HotKey="F11"       Command="{Binding WarmResetCommand}" />
                <MenuItem Header="Reset (_Cold)"    HotKey="Shift+F11" Command="{Binding ColdResetCommand}" />
                <Separator />
                <MenuItem Header="_Step"            HotKey="F8"        Command="{Binding StepCommand}" />
                <Separator />
                <MenuItem Header="_Turbo speed"     HotKey="F6"        Command="{Binding ToggleTurboCommand}"
                          IsChecked="{Binding IsTurbo}" />
                <Separator />
                <MenuItem Header="Screens_hot"      HotKey="F12"       Command="{Binding ScreenshotCommand}" />
            </MenuItem>
            <MenuItem Header="_Config">
                <MenuItem Header="_Machine configuration…" Command="{Binding OpenConfigCommand}"
                          ToolTip.Tip="Change RAM, SLOT1, monitor ROM — applies on cold reset" />
            </MenuItem>
            <MenuItem Header="_Cassette">
                <MenuItem Header="_Open Deck window" Command="{Binding OpenCassetteDeckCommand}" />
                <Separator />
                <MenuItem Header="_Mount…"           Command="{Binding CassetteVm.MountCommand}"
                          ToolTip.Tip="Insert a .cas cassette image (also drag-drop onto display)" />
                <MenuItem Header="_Eject"            Command="{Binding CassetteVm.EjectCommand}"
                          ToolTip.Tip="Remove the current cassette" />
            </MenuItem>
            <MenuItem Header="_View">
                <!-- Display mode (radio group via IsChecked + command) -->
                <MenuItem Header="Mode: _Interlaced (default)"
                          IsChecked="{Binding IsModeInterlaced}"
                          Command="{Binding SetDisplayModeCommand}"
                          CommandParameter="{x:Static rendering:DisplayMode.Interlaced}"
                          ToolTip.Tip="Present every 50 Hz field — authentic interlace comb on fast motion" />
                <MenuItem Header="Mode: _Progressive"
                          IsChecked="{Binding IsModeProgressive}"
                          Command="{Binding SetDisplayModeCommand}"
                          CommandParameter="{x:Static rendering:DisplayMode.Progressive}"
                          ToolTip.Tip="Composite both fields (25 Hz) — no comb, full vertical detail" />
                <MenuItem Header="Mode: _Even field only"
                          IsChecked="{Binding IsModeEvenOnly}"
                          Command="{Binding SetDisplayModeCommand}"
                          CommandParameter="{x:Static rendering:DisplayMode.EvenOnly}"
                          ToolTip.Tip="Show only the even field, line-doubled" />
                <MenuItem Header="Mode: _Odd field only (smoothed)"
                          IsChecked="{Binding IsModeOddOnly}"
                          Command="{Binding SetDisplayModeCommand}"
                          CommandParameter="{x:Static rendering:DisplayMode.OddOnly}"
                          ToolTip.Tip="Show only the odd (CRS-smoothed) field, line-doubled" />
                <Separator />
                <MenuItem Header="_Integer scaling"
                          IsChecked="{Binding IntegerScale}"
                          Command="{Binding ToggleIntegerScaleCommand}"
                          ToolTip.Tip="Scale by whole-pixel multiples only — crisp pixels, black borders" />
                <MenuItem Header="PAL _aspect ratio (4:3)"
                          IsChecked="{Binding PalAspect}"
                          Command="{Binding TogglePalAspectCommand}"
                          ToolTip.Tip="Maintain 4:3 ratio (letterbox); off = stretch to fill" />
                <Separator />
                <MenuItem Header="_Scanline effect"
                          IsChecked="{Binding ShowScanlines}"
                          Command="{Binding ToggleScanlinesCommand}"
                          ToolTip.Tip="Simulate CRT scanline gaps" />
                <MenuItem Header="Contention cell _overlay"
                          IsChecked="{Binding ShowDebugOverlay}"
                          Command="{Binding ToggleDebugOverlayCommand}"
                          ToolTip.Tip="Highlight character cells corrupted by CPU-vs-video bus contention" />
                <Separator />
                <MenuItem Header="_Mute audio"
                          IsChecked="{Binding AudioMute}"
                          Command="{Binding ToggleAudioMuteCommand}"
                          ToolTip.Tip="Silence the 1-bit beeper" />
            </MenuItem>
        </Menu>

        <!-- ── Toolbar ────────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#2d2d2d"
                BorderBrush="#444" BorderThickness="0,0,0,1"
                Padding="4,2">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Command="{Binding ToggleRunPauseCommand}"
                        Content="{Binding RunPauseHeader}"
                        MinWidth="56" ToolTip.Tip="Run / Pause (F5)" />
                <Button Command="{Binding WarmResetCommand}"
                        Content="↺ Warm" MinWidth="60"
                        ToolTip.Tip="Warm Reset — preserves RAM (F11)" />
                <Button Command="{Binding ColdResetCommand}"
                        Content="↺ Cold" MinWidth="60"
                        ToolTip.Tip="Cold Reset — clears RAM (Shift+F11)" />
                <Button Command="{Binding StepCommand}"
                        Content="Step" MinWidth="46"
                        ToolTip.Tip="Single-step (F8, only when paused)" />
                <Separator />
                <Button Command="{Binding ToggleTurboCommand}"
                        MinWidth="56" ToolTip.Tip="Toggle turbo speed (F6)">
                    <Button.Content>
                        <TextBlock>
                            <Run Text="⚡" />
                            <Run Text="{Binding IsTurbo, StringFormat={}Turbo: {0}}" />
                        </TextBlock>
                    </Button.Content>
                </Button>
                <Separator />
                <Button Command="{Binding ScreenshotCommand}"
                        Content="📷" MinWidth="36"
                        ToolTip.Tip="Save screenshot to Pictures (F12)" />
            </StackPanel>
        </Border>

        <!-- ── Status bar ─────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#1e1e1e"
                BorderBrush="#444" BorderThickness="0,1,0,0"
                Padding="6,2">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <!-- Emulation state -->
                <TextBlock Text="{Binding StateText}"
                           Foreground="{Binding StateText, Converter={x:Static local:StateTextToColorConverter.Instance}}"
                           FontSize="11" VerticalAlignment="Center" />
                <!-- Speed -->
                <TextBlock Text="{Binding SpeedText}"
                           Foreground="#aaa" FontSize="11" VerticalAlignment="Center" />
                <!-- Cassette LED -->
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding CassetteActive, Converter={x:Static local:BoolToLedBrushConverter.Instance}}" />
                    <TextBlock Text="CAS" Foreground="#888" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
                <!-- Model -->
                <TextBlock Text="{Binding ModelText}"
                           Foreground="#888" FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ── Display ────────────────────────────────────────────────────────── -->
        <rendering:DisplayControl x:Name="Display"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch" />
    </DockPanel>
</Window>
