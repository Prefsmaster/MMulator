<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:P2000.UI.ViewModels"
        xmlns:local="using:P2000.UI.Views"
        x:DataType="vm:MemoryWatchVm"
        x:Class="P2000.UI.Views.MemoryWatchWindow"
        Title="{Binding Title}"
        Width="640" Height="370"
        MinWidth="500" MinHeight="250"
        CanResize="True"
        Background="#1a1a1a">

    <DockPanel Margin="6">

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#252525" BorderBrush="#444" BorderThickness="1"
                CornerRadius="3" Padding="6,4" Margin="0,0,0,4">
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Base:" FontSize="11" Foreground="#888" VerticalAlignment="Center" />
                    <TextBox x:Name="AddressBox"
                             MinWidth="70" FontFamily="Consolas,Courier New,monospace"
                             FontSize="11" Watermark="e.g. 5000"
                             ToolTip.Tip="Hex address (press Enter or click Go)" />
                    <TextBlock Text="Length:" FontSize="11" Foreground="#888" VerticalAlignment="Center" />
                    <TextBox x:Name="LengthBox"
                             MinWidth="60" FontFamily="Consolas,Courier New,monospace"
                             FontSize="11" Text="0100"
                             ToolTip.Tip="Hex byte count (press Enter or click Go)" />
                    <Button Content="Go" MinWidth="36" FontSize="10"
                            Click="OnGoClicked"
                            ToolTip.Tip="Jump to entered address / resize to entered length" />
                    <Separator />
                    <TextBlock Text="Follow:" FontSize="11" Foreground="#888" VerticalAlignment="Center" />
                    <ComboBox MinWidth="60" FontSize="10"
                              ItemsSource="{x:Static vm:MemoryWatchVm.FollowOptions}"
                              SelectedItem="{Binding Follow}"
                              ToolTip.Tip="Auto-track a register pair when paused" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Save range to file…" FontSize="10"
                            Click="OnSaveRangeClicked"
                            ToolTip.Tip="Prompts for a start address + length (defaults to this window's range) and dumps it to a raw binary file" />
                    <Separator />
                    <TextBlock Text="To:" FontSize="11" Foreground="#888" VerticalAlignment="Center" />
                    <TextBox MinWidth="70" FontFamily="Consolas,Courier New,monospace"
                             FontSize="11" Text="{Binding LoadAddressText}"
                             ToolTip.Tip="Target hex address for the loaded file" />
                    <Button Content="Load file to address…" FontSize="10"
                            Command="{Binding LoadFileToAddressCommand}"
                            ToolTip.Tip="Write a raw binary file into RAM at the target address" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Column header ──────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Padding="4,0,4,2">
            <TextBlock Text="Addr      00 01 02 03 04 05 06 07  08 09 0A 0B 0C 0D 0E 0F  ASCII"
                       FontFamily="Consolas,Courier New,monospace"
                       FontSize="10" Foreground="#555" />
        </Border>

        <!-- ── Memory rows ────────────────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Background="#111">
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:MemoryWatchRow">
                        <Grid ColumnDefinitions="52,*,92" Margin="4,0">
                            <!-- Address -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Address}"
                                       FontFamily="Consolas,Courier New,monospace"
                                       FontSize="11" Foreground="#888"
                                       VerticalAlignment="Center" />
                            <!-- Hex bytes -->
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Bytes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:HexByteVm">
                                        <TextBlock Text="{Binding Hex}"
                                                   FontFamily="Consolas,Courier New,monospace"
                                                   FontSize="11"
                                                   Foreground="{Binding IsChanged,
                                                       Converter={x:Static local:BoolToChangedBrushConverter.Instance}}"
                                                   Margin="0,0,4,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- ASCII -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Ascii}"
                                       FontFamily="Consolas,Courier New,monospace"
                                       FontSize="11" Foreground="#666"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
