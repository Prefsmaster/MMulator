<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:P2000.UI.ViewModels"
        xmlns:rendering="using:P2000.UI.Rendering"
        x:DataType="vm:VramWindowVm"
        x:Class="P2000.UI.Views.VramWindow"
        Title="VRAM — P2000T"
        Width="720" Height="380"
        MinWidth="500" MinHeight="260"
        CanResize="True"
        Background="#1a1a1a">

    <DockPanel>

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#252525" BorderBrush="#444" BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="VRAM (80×24)" FontSize="11" FontWeight="SemiBold"
                           Foreground="#aaa" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PanX, StringFormat='PanX: {0}'}"
                           FontSize="11" Foreground="#888"
                           FontFamily="Consolas,Courier New,monospace"
                           VerticalAlignment="Center" />
                <Button Content="Hex"
                        Command="{Binding ToggleHexCommand}"
                        MinWidth="40" FontSize="10"
                        ToolTip.Tip="Toggle hex / glyph display" />
            </StackPanel>
        </Border>

        <!-- ── VRAM grid ──────────────────────────────────────────────────── -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#111"
                      Padding="4">
            <rendering:VramGridControl
                VramData="{Binding VramData}"
                Corruption="{Binding Corruption}"
                PanX="{Binding PanX}"
                ShowHex="{Binding ShowHex}" />
        </ScrollViewer>

    </DockPanel>

</Window>
